{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "automergeType": "pr",
  "platformAutomerge": true,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on monday"],
    "timezone": "Asia/Tokyo",
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Auto-merge patch and minor updates",
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "description": "Require manual review for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Group non-major dev dependencies",
      "groupName": "dev dependencies",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "description": "Group Sanity packages",
      "groupName": "sanity",
      "matchPackageNames": ["/^@sanity//", "/^sanity$/", "/^next-sanity$/"]
    },
    {
      "description": "Group Next.js packages",
      "groupName": "next.js",
      "matchPackageNames": ["/^next$/", "/^@next//"]
    },
    {
      "description": "Group React packages",
      "groupName": "react",
      "matchPackageNames": ["/^react$/", "/^react-dom$/"]
    },
    {
      "description": "Group TanStack packages",
      "groupName": "tanstack",
      "matchPackageNames": ["/^@tanstack//"]
    },
    {
      "description": "Group Oxc toolchain",
      "groupName": "oxc",
      "matchPackageNames": ["/^oxlint$/", "/^oxfmt$/"]
    },
    {
      "description": "Group testing packages",
      "groupName": "testing",
      "matchPackageNames": ["/^vitest/", "/^@vitest//", "/^@playwright//", "/^playwright$/"]
    },
    {
      "description": "Group TypeScript and types",
      "groupName": "typescript",
      "matchPackageNames": ["/^typescript$/", "/^@types//"]
    }
  ]
}
